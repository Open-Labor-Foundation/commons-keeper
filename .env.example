# GitHub token — needs: repo read, issues write, checks write on labor-commons.
# For the security-review loop below, it additionally needs repo read, issues
# write, and pull-request write on every repo listed in
# config/security-review-targets.json (PR write is for dependency-mitigation
# proposals — see below; it never pushes to main directly).
GH_TOKEN=

# Target repository (org/repo)
TARGET_REPO=Open-Labor-Foundation/labor-commons

# Keeper mode: passive (default) | assisted | autonomous
KEEPER_MODE=passive

# Keeper trigger: schedule | manual | git
KEEPER_TRIGGER=schedule

# Optional: Featherless API key for LLM-assisted review in autonomous mode
FEATHERLESS_API_KEY=

# How often each maintenance loop runs, in seconds. The container runs both
# loops for its entire lifetime — no external cron or scheduler needed.
KEEPER_CATALOG_INTERVAL_SECONDS=3600
KEEPER_SECURITY_INTERVAL_SECONDS=86400

# --- Security review (src/security-review.mjs) ---
# Two independent checks per repo in config/security-review-targets.json:
# an LLM code-logic pass over changed code, and an `npm audit` dependency
# pass (real CVE/GHSA data — needs no LLM key, always runs).
#
# Code-logic pass: requires FEATHERLESS_API_KEY above (or set
# SECURITY_REVIEW_API_KEY to use a separate key/provider). Without a key
# this pass is skipped — logged, not fatal — and the dependency audit still
# runs.
# SECURITY_REVIEW_API_KEY=
# SECURITY_REVIEW_BASE_URL=https://api.featherless.ai/v1
# SECURITY_REVIEW_MODEL=Qwen/Qwen3-32B
#
# Dependency audit: minimum severity that gets filed as an issue —
# info | low | moderate | high | critical
# SECURITY_REVIEW_DEPENDENCY_SEVERITY=high
#
# Dependency mitigation: for direct-dependency findings with no upstream
# fix, propose an in-repo mitigation as a PR (never merged automatically,
# never touches a third-party repo — see README). Needs the same LLM key
# as the code-logic pass above; set to "false" to disable and only file the
# informational issue.
# SECURITY_REVIEW_PROPOSE_MITIGATIONS=true
